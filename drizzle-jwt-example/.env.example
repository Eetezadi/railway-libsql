# LibSQL Database Configuration with JWT Authentication

# Database URL - Format depends on your deployment:
# Local: http://localhost:8080
# Railway: https://your-app.railway.app
# Custom domain: https://db.yourdomain.com
DATABASE_URL=http://localhost:8080

# JWT Authentication Token
# Generate this using the jwt-utils scripts
DATABASE_AUTH_TOKEN=your-jwt-token-here

# Example JWT token format (do not use in production):
# DATABASE_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyIiwiaWF0IjoxNzA0MDY3MjAwLCJleHAiOjE3MDY2NTkyMDAsInAiOiJydyJ9.signature_here